# [Immich Database 설정]
# Immich가 사용하는 PostgreSQL 접속 정보입니다. 
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_DATABASE_NAME=immich

# [VWORLD API 설정 - 기본 역지오코딩용]
VWORLD_API_KEY=your_vworld_api_key_here

# [NAVER Cloud Platform API 설정 - 건물명 보강용]
# 건물명/POI를 붙일 때만 사용합니다.
NAVER_CLIENT_ID=your_client_id_here
NAVER_CLIENT_SECRET=your_client_secret_here

# [동작 설정]
# INTERVAL_HOURS: 업데이트 주기 (시간 단위, 기본값: 24)
# STEP_DELAY_MS: 클러스터 단위 지연 시간 (밀리초 단위)
# CLUSTER_RADIUS_METERS: 가까운 사진을 같은 장소로 묶는 반경 (기본값: 15)
# APPEND_BUILDING_NAME: true면 Naver API로 건물명을 붙임, false면 법정동까지만 저장
INTERVAL_HOURS=24
STEP_DELAY_MS=100
CLUSTER_RADIUS_METERS=15
APPEND_BUILDING_NAME=true
